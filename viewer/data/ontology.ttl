<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_DataCadence> a gbk:assessment,
        gb:Node ;
    rdfs:label "Data Cadence: Pass" ;
    gb:description "SoH readings monthly at most. Lifecycle events are rare." ;
    gb:group gbg:eu-battery-regulation ;
    gb:nodeId "ca-datacadence" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_Fee> a gbk:assessment,
        gb:Node ;
    rdfs:label "Fee Alignment: Pass" ;
    gb:description "Manufacturers pay ~$0.10-0.15 per reading. Compliance value far exceeds cost." ;
    gb:group gbg:eu-battery-regulation ;
    gb:nodeId "ca-fee" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_Identity> a gbk:assessment,
        gb:Node ;
    rdfs:label "Identity Delegation: Pass" ;
    gb:description "NFC secure element (SE050) signs readings. Consumer taps phone, no wallet." ;
    gb:group gbg:eu-battery-regulation ;
    gb:nodeId "ca-identity" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_Liveness> a gbk:assessment,
        gb:Node ;
    rdfs:label "Liveness: Pass" ;
    gb:description "Penalties are set by Member States under Art. 93. Slot-based timeouts for readings remain enforceable at protocol level." ;
    gb:group gbg:eu-battery-regulation ;
    gb:nodeId "ca-liveness" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_Sequential> a gbk:assessment,
        gb:Node ;
    rdfs:label "Sequential Access: Pass" ;
    gb:description "One manufacturer per trie. Relay on repurposing." ;
    gb:group gbg:eu-battery-regulation ;
    gb:nodeId "ca-sequential" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#G_FreshReading> a gbk:guard,
        gb:Node ;
    rdfs:label "Fresh COSE_Sign1 BMS reading valid" ;
    gb:description "Fresh COSE_Sign1 BMS reading valid" ;
    gb:group gbg:framework ;
    gb:nodeId "g-freshreading" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#G_RewardPositive> a gbk:guard,
        gb:Node ;
    rdfs:label "nextReward > 0" ;
    gb:description "nextReward > 0" ;
    gb:group gbg:framework ;
    gb:nodeId "g-rewardpositive" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#TR_MfrRegulator> a gbk:trust,
        gb:Node ;
    rdfs:label "Medium: Selective reporting" ;
    gb:description "Risk: Selective reporting. Mitigation: Completeness proofs via MPT" ;
    gb:group gbg:eu-battery-regulation ;
    gb:nodeId "tr-mfrregulator" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_DataCadence> a gbk:assessment,
        gb:Node ;
    rdfs:label "Data Cadence: Pass" ;
    gb:description "Consent events, breach notifications (72h), rights requests (1 month), DPIAs — all event-driven or periodic. No real-time streaming." ;
    gb:group gbg:gdpr ;
    gb:nodeId "ca-datacadence" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_Fee> a gbk:assessment,
        gb:Node ;
    rdfs:label "Fee Alignment: Pass" ;
    gb:description "Controllers pay. Compliance cost (~€0.10-0.15 per record) negligible vs fine exposure." ;
    gb:group gbg:gdpr ;
    gb:nodeId "ca-fee" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_Identity> a gbk:assessment,
        gb:Node ;
    rdfs:label "Identity Delegation: Pass" ;
    gb:description "Process mode. Data subjects exercise rights through digital channels. The signing function maps to the authenticated request." ;
    gb:group gbg:gdpr ;
    gb:nodeId "ca-identity" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_Liveness> a gbk:assessment,
        gb:Node ;
    rdfs:label "Liveness: Pass" ;
    gb:description "Up to €20M / 4% global turnover. 72h breach deadline. 1-month rights response. Strongest penalties of any regulation analysed." ;
    gb:group gbg:gdpr ;
    gb:nodeId "ca-liveness" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_Sequential> a gbk:assessment,
        gb:Node ;
    rdfs:label "Sequential Access: Pass" ;
    gb:description "Single controller per trie. Rights requests follow a relay: subject → controller → response." ;
    gb:group gbg:gdpr ;
    gb:nodeId "ca-sequential" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#G_NoExistingCommitment> a gbk:guard,
        gb:Node ;
    rdfs:label "No existing commitment on leaf" ;
    gb:description "No existing commitment on leaf" ;
    gb:group gbg:framework ;
    gb:nodeId "g-noexistingcommitment" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#G_StandingNotSuspended> a gbk:guard,
        gb:Node ;
    rdfs:label "Controller standing ≠ suspended (regulation trie)" ;
    gb:description "Controller standing ≠ suspended (regulation trie)" ;
    gb:group gbg:framework ;
    gb:nodeId "g-standingnotsuspended" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#TR_ControllerProcessor> a gbk:trust,
        gb:Node ;
    rdfs:label "Medium: Processor claims it followed instructions" ;
    gb:description "Risk: Processor claims it followed instructions. Mitigation: On-chain agreement hash, activity proofs" ;
    gb:group gbg:gdpr ;
    gb:nodeId "tr-controllerprocessor" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#TR_ConsumerConsumer> a gbk:trust,
