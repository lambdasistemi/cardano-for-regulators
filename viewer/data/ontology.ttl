@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CommitmentCleared> a gbk:invariant,
        gb:Node ;
    rdfs:label "Proved: commitment_cleared_after_submit: After SubmitReading, commit" ;
    gb:description "commitment_cleared_after_submit: After SubmitReading, commitment = Nothing" ;
    gb:group gbg:framework ;
    gb:nodeId "commitmentcleared" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#MPTConsistency> a gbk:invariant,
        gb:Node ;
    rdfs:label "Proved: transition_preserves_consistency: two-leaf update preserves " ;
    gb:description "transition_preserves_consistency: two-leaf update preserves MPT validity" ;
    gb:group gbg:framework ;
    gb:nodeId "mptconsistency" .

<https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#RewardMonotonicity> a gbk:invariant,
        gb:Node ;
    rdfs:label "Proved: credit_increases: reward > 0 → rewardsAccumulated strictly i" ;
    gb:description "credit_increases: reward > 0 → rewardsAccumulated strictly increases" ;
    gb:group gbg:framework ;
    gb:nodeId "rewardmonotonicity" .

