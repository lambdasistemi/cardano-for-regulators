[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "SoH readings monthly at most. Lifecycle events are rare." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_DataCadence> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#DataCadence> .

[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "One manufacturer per trie. Relay on repurposing." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_Sequential> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#SequentialAccess> .

[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "Penalties are set by Member States under Art. 93. Slot-based timeouts for readings remain enforceable at protocol level." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_Liveness> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#Liveness> .

[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "Manufacturers pay ~$0.10-0.15 per reading. Compliance value far exceeds cost." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_Fee> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#FeeAlignment> .

[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "NFC secure element (SE050) signs readings. Consumer taps phone, no wallet." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/battery#CA_Identity> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#IdentityDelegation> .

[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "Consent events, breach notifications (72h), rights requests (1 month), DPIAs — all event-driven or periodic. No real-time streaming." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_DataCadence> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#DataCadence> .

[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "Single controller per trie. Rights requests follow a relay: subject → controller → response." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_Sequential> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#SequentialAccess> .

[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "Up to €20M / 4% global turnover. 72h breach deadline. 1-month rights response. Strongest penalties of any regulation analysed." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_Liveness> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#Liveness> .

[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "Controllers pay. Compliance cost (~€0.10-0.15 per record) negligible vs fine exposure." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_Fee> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#FeeAlignment> .

[] a gb:EdgeAssertion ;
    rdfs:label "Pass" ;
    gb:description "Process mode. Data subjects exercise rights through digital channels. The signing function maps to the authenticated request." ;
    gb:from <https://lambdasistemi.github.io/cardano-for-regulators/ontology/gdpr#CA_Identity> ;
    gb:to <https://lambdasistemi.github.io/cardano-for-regulators/ontology#IdentityDelegation> .

