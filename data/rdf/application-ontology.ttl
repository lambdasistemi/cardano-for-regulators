@prefix gb: <https://lambdasistemi.github.io/graph-browser/vocab/terms#> .
@prefix gbkind: <https://lambdasistemi.github.io/graph-browser/vocab/kinds#> .
@prefix gbgroup: <https://lambdasistemi.github.io/graph-browser/vocab/groups#> .
@prefix gbedge: <https://lambdasistemi.github.io/graph-browser/vocab/edges#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://lambdasistemi.github.io/graph-browser/vocab/application-ontology> a owl:Ontology ;
  rdfs:label "Graph Browser application vocabulary" ;
  dcterms:description "Repository-specific vocabulary generated from graph-browser config and graph data." ;
  owl:imports <https://lambdasistemi.github.io/graph-browser/vocab/ontology> ;
  owl:versionInfo "0.1.0" .

gbkind:artifact a owl:Class ;
  rdfs:label "On-chain Artifact" ;
  gb:kindId "artifact" ;
  gb:color "#d2a8ff" ;
  gb:shape "round-rectangle" ;
  rdfs:subClassOf gb:Node .

gbkind:case-study a owl:Class ;
  rdfs:label "Case Study" ;
  gb:kindId "case-study" ;
  gb:color "#f0883e" ;
  gb:shape "barrel" ;
  rdfs:subClassOf gb:Node .

gbkind:concept a owl:Class ;
  rdfs:label "Concept" ;
  gb:kindId "concept" ;
  gb:color "#56d364" ;
  gb:shape "star" ;
  rdfs:subClassOf gb:Node .

gbkind:constraint a owl:Class ;
  rdfs:label "Constraint" ;
  gb:kindId "constraint" ;
  gb:color "#e3b341" ;
  gb:shape "round-pentagon" ;
  rdfs:subClassOf gb:Node .

gbkind:gdpr-element a owl:Class ;
  rdfs:label "GDPR Element" ;
  gb:kindId "gdpr-element" ;
  gb:color "#79c0ff" ;
  gb:shape "ellipse" ;
  rdfs:subClassOf gb:Node .

gbkind:party a owl:Class ;
  rdfs:label "Party" ;
  gb:kindId "party" ;
  gb:color "#58a6ff" ;
  gb:shape "round-octagon" ;
  rdfs:subClassOf gb:Node .

gbkind:protocol a owl:Class ;
  rdfs:label "Protocol Pattern" ;
  gb:kindId "protocol" ;
  gb:color "#f778ba" ;
  gb:shape "diamond" ;
  rdfs:subClassOf gb:Node .

gbkind:risk a owl:Class ;
  rdfs:label "Risk / Tension" ;
  gb:kindId "risk" ;
  gb:color "#f85149" ;
  gb:shape "triangle" ;
  rdfs:subClassOf gb:Node .


gbgroup:cases a gb:Group ;
  rdfs:label "cases" ;
  gb:groupId "cases" .

gbgroup:constraints a gb:Group ;
  rdfs:label "constraints" ;
  gb:groupId "constraints" .

gbgroup:foundation a gb:Group ;
  rdfs:label "foundation" ;
  gb:groupId "foundation" .

gbgroup:gdpr a gb:Group ;
  rdfs:label "gdpr" ;
  gb:groupId "gdpr" .

gbgroup:modes a gb:Group ;
  rdfs:label "modes" ;
  gb:groupId "modes" .

gbgroup:protocols a gb:Group ;
  rdfs:label "protocols" ;
  gb:groupId "protocols" .

gbgroup:schema a gb:Group ;
  rdfs:label "schema" ;
  gb:groupId "schema" .

gbgroup:tensions a gb:Group ;
  rdfs:label "tensions" ;
  gb:groupId "tensions" .


gbedge:argues%20for a owl:ObjectProperty ;
  rdfs:label "argues for" ;
  rdfs:subPropertyOf gb:EdgeRelation ;
  gb:edgeLabel "argues for" ;
  rdfs:domain gb:Node ;
  rdfs:range gb:Node .

